{
  "name": "ripple-effect",
  "version": "1.0.0",
  "description": "Ripple Effect — Global Energy Price & Logistics Alert Dashboard",
  "scripts": {
    "server": "node server/server.js",
    "server:dev": "nodemon server/server.js",
    "client": "npm run dev --prefix client",
    "client:build": "npm run build --prefix client",
    "dev": "concurrently \"npm run server:dev\" \"npm run client\"",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.4.1",
    "node-cron": "^3.0.3",
    "sentiment": "^5.0.2",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}
